# Copy to hermes-chat.env and fill in secrets. Do not commit hermes-chat.env.
#
# After git pull or editing server.py: ./restart-after-code-change.sh   (or --pull first)

HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=

# Same profile directory as user hermes-gateway.service (not the repo path).
HERMES_HOME=/home/YOUR_USER/.hermes/profiles/dpc

# Same checkout + venv as gateway WorkingDirectory / ExecStart (typically ~/.hermes/hermes-agent).
HERMES_AGENT_DIR=/home/YOUR_USER/.hermes/hermes-agent

# Optional: path to ``setup_repo.md`` copied into each Hermes Chat project root when missing.
# When unset and this file lives next to ``server.py``, Hermes Chat sets it automatically.
# HERMES_CHAT_SETUP_REPO_MD=/path/to/hermes-chat/setup_repo.md

# Tailscale Serve to this port: use CHAT_HOST=127.0.0.1 (see TAILSCALE-SERVE.md). Default :: avoids
# ERR_FAILED when opening http://localhost:PORT (browser may use IPv6 first).
CHAT_HOST=::
CHAT_PORT=3000

# URL users open in the browser (Tailscale HTTPS). Keeps /api/hermes-chat-meta hints correct.
# HERMES_CHAT_PUBLIC_URL=https://your-host.tail1234.ts.net

# Optional: Settings → “Restart gateway” / “Restart chat server” call systemctl on these units
# (user: `systemctl --user cat <unit>` must succeed, or use sudo -n for system units).
# HERMES_GATEWAY_SYSTEMD_UNIT=hermes-gateway.service
# HERMES_CHAT_SYSTEMD_UNIT=hermes-chat.service
#
# If you run chat via `python server.py` without systemd, set a restart command instead (shlex; no shell):
# HERMES_RESTART_CHAT_CMD=/path/to/hermes-chat/restart-after-code-change.sh
# HERMES_RESTART_GATEWAY_CMD=/path/to/your/restart-gateway.sh

# Leave PEM vars unset when Tailscale terminates TLS (Serve → http://127.0.0.1:3000).
# Optional: mkcert PEM whose SAN includes your full MagicDNS name + tailnet IP, then:
#   tailscale serve --bg https+insecure://127.0.0.1:3000
# Example (paths under HERMES_AGENT checkout; *.pem is gitignored):
# CHAT_SSL_CERTFILE=/home/YOUR_USER/certs/your-host+1.pem
# CHAT_SSL_KEYFILE=/home/YOUR_USER/certs/your-host+1-key.pem
