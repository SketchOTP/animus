# === ANIMUS Configuration ===
# Copy to animus.env (in repo root or next to animus-chat/server.py) and fill values.
# Default dev port is 3001 so it does not collide with another stack on 3000.

# --- Server ---
CHAT_HOST=127.0.0.1
CHAT_PORT=3001

# --- Hermes gateway (OpenAI-compatible) ---
HERMES_API_URL=http://127.0.0.1:8642
# Bearer the ANIMUS chat *server* sends to HERMES_API_URL. Leave blank when your gateway
# has no API key configured (typical local Hermes). If API_SERVER_KEY exists in
# ~/.hermes/.env, install.sh runs installer/merge-hermes-gateway-auth.py to copy it here
# when this line is still blank; the server also reads that file at runtime when unset.
HERMES_API_KEY=

# --- Hermes web dashboard (optional; enables server-side calls to dashboard REST) ---
# When `hermes dashboard` is running (default http://127.0.0.1:9119), open the dashboard in a browser,
# DevTools → Console, run: copy(window.__HERMES_SESSION_TOKEN__) then paste below (or sniff
# X-Hermes-Session-Token on any /api/* request). Enables ANIMUS server calls to POST /api/gateway/restart,
# GET /api/skills, PUT /api/skills/toggle, GET /api/analytics/usage, and mirror model changes via PUT /api/config.
# HERMES_DASHBOARD_URL=http://127.0.0.1:9119
# HERMES_DASHBOARD_SESSION_TOKEN=

# --- Hermes Agent checkout (ANIMUS monorepo) ---
HERMES_AGENT_DIR=${INSTALL_DIR}/hermes-agent
# Use an absolute path under systemd (EnvironmentFile does not expand ${HOME}).
HERMES_HOME=/home/you/.hermes/profiles/default

# --- Optional: public browser URL (Tailscale / reverse proxy) ---
# HERMES_CHAT_PUBLIC_URL=https://your-machine.example.ts.net
# SKIP_ANIMUS_DESKTOP_LAUNCHER=1  # skip ~/.local/share/applications + Desktop shortcut (installer/create-desktop-launcher.sh)
# SKIP_ANIMUS_SSHPASS=1  # skip installer/ensure-sshpass.sh (SSH password "Test" in Settings needs sshpass on PATH)

# --- Auto-updates ---
# URL of the ANIMUS update manifest (JSON). Use your deployed animus-site (Vercel) or any HTTPS URL that returns JSON.
# Buyer-facing site (only hostname we use in docs/zips): https://animusai.vercel.app/api/latest.json
# If unset or blank, the app uses the buyer manifest at https://animusai.vercel.app/api/latest.json (override for self-hosted feeds).
ANIMUS_UPDATE_URL=https://animusai.vercel.app/api/latest.json

# --- Systemd restart targets (optional) ---
# HERMES_GATEWAY_SYSTEMD_UNIT=hermes-gateway.service
# HERMES_CHAT_SYSTEMD_UNIT=animus.service

# --- Hermes binary (optional; otherwise PATH) ---
# HERMES_BIN=

# --- AI provider keys (also configurable in the onboarding wizard) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Piper TTS (optional; Read aloud server-side voices) ---
# PIPER_BIN=/usr/local/bin/piper
# PIPER_VOICES_DIR=/var/lib/animus/piper-voices
# SKIP_ANIMUS_PIPER_VOICES=1  # disable automatic Hugging Face voice download on the server
# Default models land in ~/.local/share/piper (auto-download + installer/fetch-piper-voices.sh).

# --- Data ---
DATA_DIR=./data

# --- Slack integration (optional; cron “Deliver to Slack”) ---
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#animus-notifications
